# RBAC — equipe interna (Discord user IDs separados por vírgula)
# Apenas IDs listados aqui recebem SYSTEM_ADMIN / SYSTEM_MODERATOR
RADARZAP_SYSTEM_ADMIN_DISCORD_IDS=seu_discord_user_id
RADARZAP_SYSTEM_MODERATOR_DISCORD_IDS=

# Discord
DISCORD_TOKEN=seu_token_do_bot
DISCORD_CLIENT_ID=seu_client_id
DISCORD_CLIENT_SECRET=seu_client_secret
# Opcional: registro instantâneo de slash commands em um servidor
DISCORD_GUILD_ID=

# Banco de dados (Docker local)
MONGO_PASSWORD=altere_esta_senha
MONGODB_URL=mongodb://admin:altere_esta_senha@localhost:27017/discord-whatsapp?authSource=admin

# Redis (Docker expõe 6380 → 6379 no container)
REDIS_URL=redis://localhost:6380

# JWT / sessão
JWT_SECRET=gerar_string_aleatoria_longa
JWT_EXPIRES_IN=7d
SESSION_SECRET=gerar_outra_string_aleatoria

# API
API_PORT=3000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3001
# URL que você abre no browser — DEVE ser a mesma origem do OAuth (cookie de sessão)
# Vite dev: http://localhost:5174  |  Só backend: http://localhost:3001
FRONTEND_URL=http://localhost:5174
# No Discord Developer Portal → OAuth2 → Redirects, adicione:
#   {FRONTEND_URL}/auth/discord/callback

# WhatsApp (Baileys) — timeout Redis/cache; credenciais persistem no Mongo por 30 dias
WHATSAPP_SESSION_TIMEOUT=2592000000
WHATSAPP_RECONNECT_ATTEMPTS=3
WHATSAPP_HEADLESS=true
WHATSAPP_QRCODE_LIMIT=6
WHATSAPP_CONNECT_QR_WAIT_MS=5000

# Filas BullMQ
QUEUE_CONCURRENCY=5
QUEUE_MAX_RETRY=3
QUEUE_DELAY_MULTIPLIER=2000

# Rate limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logs
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=./logs/app.log

# Ambiente
NODE_ENV=development
# Em Docker, cada container define SERVICE_NAME: discord-bot | whatsapp-service | queue-processor | api-gateway
# SERVICE_NAME=
