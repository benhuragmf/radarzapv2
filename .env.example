# RBAC — equipe interna (Discord user IDs separados por vírgula)
# Apenas IDs listados aqui recebem SYSTEM_ADMIN / SYSTEM_MODERATOR
RADARCHAT_SYSTEM_ADMIN_DISCORD_IDS=seu_discord_user_id
RADARCHAT_SYSTEM_MODERATOR_DISCORD_IDS=

# Discord
DISCORD_TOKEN=seu_token_do_bot
DISCORD_CLIENT_ID=seu_client_id
# Opcional no frontend (dev); o painel usa GET /api/discord/bot-invite-url
# VITE_DISCORD_CLIENT_ID=1397251289838260244
DISCORD_CLIENT_SECRET=seu_client_secret
# Opcional: registro instantâneo de slash commands em um servidor
DISCORD_GUILD_ID=

# Banco de dados (Docker local — primário na VPS)
MONGO_PASSWORD=altere_esta_senha
# Use 127.0.0.1 no Windows (localhost pode ir para IPv6 e outro mongod na :27017)
MONGODB_URL=mongodb://admin:altere_esta_senha@127.0.0.1:27017/discord-whatsapp?authSource=admin

# Backup ao vivo → MongoDB Atlas (réplica espelhada a cada hora; app NÃO usa esta URL)
# Formato: mongodb+srv://USER:PASS@cluster....mongodb.net/discord-whatsapp?retryWrites=true&w=majority
# No Atlas: Network Access deve incluir o IP público da VPS.
# Retenção local (VPS): /var/backups/radarchat/mongo/
#   hourly → 3 | daily → 3 | every-3d → 3 | weekly → 3  (cron horário)
# MONGODB_BACKUP_URL=mongodb+srv://usuario:senha@cluster0.xxxxx.mongodb.net/discord-whatsapp?retryWrites=true&w=majority

# Redis (Docker expõe 6380 → 6379 no container)
REDIS_URL=redis://localhost:6380

# JWT / sessão
JWT_SECRET=gerar_string_aleatoria_longa
JWT_EXPIRES_IN=7d
SESSION_SECRET=gerar_outra_string_aleatoria
# Obrigatório em produção — sessões WA, secrets de webhook e backup criptografado
SESSION_ENCRYPTION_KEY=gerar_string_aleatoria_longa_para_sessoes_whatsapp
# BACKUP_ENCRYPT_EXPORT=true  # só produção — export JSON criptografado (ver docs/PRODUCTION.md §8)

# API
API_PORT=3000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3001
# URL que você abre no browser — DEVE ser a mesma origem do OAuth (cookie de sessão)
# Vite dev: http://localhost:5174  |  Só backend: http://localhost:3001
FRONTEND_URL=http://localhost:5174
# No Discord Developer Portal → OAuth2 → Redirects, adicione:
#   {FRONTEND_URL}/auth/discord/callback

# Google OAuth (dono da empresa — login Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Google Cloud Console → Credentials → Redirect URI:
#   {FRONTEND_URL}/auth/google/callback

# WhatsApp (Baileys) — timeout Redis/cache; credenciais persistem no Mongo por 30 dias
WHATSAPP_SESSION_TIMEOUT=2592000000
WHATSAPP_RECONNECT_ATTEMPTS=3
WHATSAPP_HEADLESS=true
WHATSAPP_QRCODE_LIMIT=6
WHATSAPP_CONNECT_QR_WAIT_MS=5000

# WhatsApp Cloud API (Meta) — Enterprise, ver docs/PRODUCTION.md §7
# META_APP_ID=
# META_APP_SECRET=
# WHATSAPP_CLOUD_VERIFY_TOKEN=
# WHATSAPP_CLOUD_API_VERSION=v21.0
# WHATSAPP_DEFAULT_CHANNEL=baileys

# Filas BullMQ
QUEUE_CONCURRENCY=5
QUEUE_MAX_RETRY=3
QUEUE_DELAY_MULTIPLIER=2000

# Rate limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# Webhooks outbound (integrações)
WEBHOOK_TIMEOUT_MS=15000
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_DELAY_MS=2000

# Integracao inbound RadarGamer -> RadarChat
RADARCHAT_API_TOKEN=
RADARCHAT_RADARGAMER_CLIENT_ID=
RADARCHAT_ALLOWED_SOURCES=radargamer
RADARCHAT_RADARGAMER_RATE_LIMIT_PER_MINUTE=30
# QA local sem criar job real em whatsapp-sending
RADARCHAT_INTEGRATION_QA_NO_SEND=false

# E-mail (convites de equipe) — use Resend OU SMTP
# Resend (recomendado): https://resend.com
RESEND_API_KEY=
MAIL_FROM=Radar Chat <noreply@seudominio.com>
# SMTP alternativo:
# SMTP_HOST=smtp.seudominio.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# Logs
LOG_LEVEL=info
LOG_FORMAT=pretty
LOG_FILE_PATH=./logs/app.log

# Ambiente
NODE_ENV=development

# ALERT_SLACK_WEBHOOK_URL=https://hooks.slack.com/...  # alerta WA desconectado

# Stripe — use npm run stripe:prices para gerar price_... R$99/R$299
# RAK recomendada: rk_test_... ou secret: sk_test_...  (mk_... = só ID no Dashboard, não usar)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_PRO=price_...
# STRIPE_PRICE_ID_ENTERPRISE=
SUBSCRIPTION_SWEEP_MS=3600000
ALLOW_DEV_BILLING=true
# NUNCA true em produção/staging — validateConfig bloqueia NODE_ENV=production
# ALLOW_DEV_API_KEY_BYPASS=true  # só dev local isolado; bypass de X-API-Key no APIGateway legado

# IA Atendimento — modo Radar Chat (OpenAI/Gemini no servidor ou painel admin /admin/ai-platform)
# RADARCHAT_AI_OPENAI_KEY=sk-proj-...
# RADARCHAT_AI_GEMINI_KEY=AIza...
# Gemini (Google AI Studio): painel → IA Atendimento → IA própria → provedor Gemini → modelo gemini-flash-latest
# COOKIE_SECURE=true             # obrigatório em produção (HTTPS)
# Em Docker, cada container define SERVICE_NAME: discord-bot | whatsapp-service | queue-processor | api-gateway
# SERVICE_NAME=
