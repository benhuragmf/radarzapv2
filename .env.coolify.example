# Radar Chat — variáveis para colar no Coolify (serviço `app`, além das geradas automaticamente)
# Compose: docker-compose.coolify.yml
#
# Coolify gera automaticamente (magic env):
#   SERVICE_PASSWORD_MONGODB, SERVICE_URL_APP, SERVICE_FQDN_APP
#
# Preencha no painel Coolify → Environment Variables (Build & Runtime)

# --- Obrigatórias (produção) ---
JWT_SECRET=
SESSION_SECRET=
SESSION_ENCRYPTION_KEY=
# Nunca rotacionar SESSION_ENCRYPTION_KEY com WA conectado

DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- E-mail equipe ---
RESEND_API_KEY=
MAIL_FROM=Radar Chat <noreply@radarchat.com.br>

# --- Billing (Stripe Live em prod) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
# ALLOW_DEV_BILLING não definir em produção

# --- Admin plataforma ---
RADARCHAT_SYSTEM_ADMIN_DISCORD_IDS=

# --- Integracao inbound RadarGamer -> RadarChat ---
RADARCHAT_API_TOKEN=
RADARCHAT_RADARGAMER_CLIENT_ID=
RADARCHAT_ALLOWED_SOURCES=radargamer
RADARCHAT_RADARGAMER_RATE_LIMIT_PER_MINUTE=30
# Manter vazio/false em producao; usar true apenas em QA local controlado
RADARCHAT_INTEGRATION_QA_NO_SEND=false

# --- Opcional ---
BACKUP_ENCRYPT_EXPORT=true
ALERT_SLACK_WEBHOOK_URL=
SENTRY_DSN=

# --- OAuth redirects (usar mesmo domínio que SERVICE_URL_APP: https://app.radarchat.com.br) ---
# Discord: {FRONTEND_URL}/auth/discord/callback
# Google:  {FRONTEND_URL}/auth/google/callback
