  "gates": {
    "build": {
      "label": "Build backend + frontend",
      "command": ["npm", "run", "build"],
      "extra": [
        ["npm", "run", "build", "--prefix", "src/services/web-dashboard/frontend"]
      ]
    },
    "atendimento": {
      "label": "Jest atendimento (CI — sem qa:prep WA)",
      "command": ["npm", "run", "qa:atendimento:jest"]
    },
    "jest-webchat-security": {
      "label": "Jest WebChat/CSRF/embed",
      "command": [
        "npm",
        "test",
        "--",
        "--testPathPattern=webchat-public-abuse|same-origin|embed-preview-origin|webchat-token",
        "--forceExit"
      ]
    },
    "jest-crm-completeness": {
      "label": "Jest CRM WebChat incompleto",
      "command": ["npm", "test", "--", "--testPathPattern=webchat-crm-completeness", "--forceExit"]
    },
    "jest-mask-secret": {
      "label": "Jest mascaramento segredos",
      "command": ["npm", "test", "--", "--testPathPattern=mask-secret", "--forceExit"]
    },
    "e2e-login": {
      "label": "Playwright login UI",
      "command": ["npx", "playwright", "test", "e2e/login.spec.ts", "--project=chromium"]
    },
    "e2e-cross-tenant": {
      "label": "Playwright cross-tenant",
      "command": ["npx", "playwright", "test", "e2e/cross-tenant-isolation.spec.ts", "--project=chromium"]
    },
    "e2e-admin": {
      "label": "Playwright admin dashboard",
      "command": ["npx", "playwright", "test", "e2e/admin-dashboard.spec.ts", "--project=chromium"]
    },
    "e2e-lgpd": {
      "label": "Playwright portal LGPD",
      "command": ["npx", "playwright", "test", "e2e/lgpd-portal.spec.ts", "--project=chromium"]
    },
    "e2e-fase1": {
      "label": "Playwright fase1 painel",
      "command": ["npx", "playwright", "test", "e2e/qa-fase1-panel.spec.ts", "--project=chromium"]
    },
    "e2e-presence": {
      "label": "Playwright presença",
      "command": ["npx", "playwright", "test", "e2e/qa-fase1-presence.spec.ts", "--project=chromium"]
    },
    "e2e-inbox": {
      "label": "Playwright inbox mock",
      "command": ["npx", "playwright", "test", "e2e/inbox-authenticated.spec.ts", "--project=chromium"]
    },
    "e2e-leads": {
      "label": "Playwright leads painel",
      "command": ["npx", "playwright", "test", "e2e/leads-panel.spec.ts", "--project=chromium"]
    },
    "e2e-attendance-modes": {
      "label": "Playwright modos atendimento",
      "command": ["npx", "playwright", "test", "e2e/attendance-modes.spec.ts", "--project=chromium"]
    }
  }
