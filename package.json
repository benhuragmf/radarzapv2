{
  "name": "radarchat",
  "version": "2.17.48",
  "private": true,
  "description": "Radar Chat — automação Discord para WhatsApp",
  "main": "dist/index.js",
  "scripts": {
    "prebuild": "node scripts/sync-widget-build.cjs",
    "build": "tsc && tsc-alias && node scripts/copy-dashboard-static.cjs",
    "start": "node dist/index.js",
    "dev": "node -r ./scripts/register-dev-logging.cjs ./node_modules/ts-node-dev/lib/bin.js --respawn --exit-child --transpile-only --debounce 2500 --ignore-watch sessions --ignore-watch data --ignore-watch test-results --ignore-watch .git --ignore-watch mocker -r tsconfig-paths/register src/index.ts",
    "dev:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-dev.ps1",
    "stripe:webhook": "powershell -ExecutionPolicy Bypass -File scripts/stripe-webhook-dev.ps1",
    "stripe:prices": "ts-node -r dotenv/config -r tsconfig-paths/register scripts/create-stripe-radarchat-prices.ts",
    "docker:prod": "docker compose -f docker-compose.prod.yml up -d --build",
    "dashboard": "ts-node -r tsconfig-paths/register start-dashboard.ts",
    "dashboard:frontend": "npm run dev --prefix src/services/web-dashboard/frontend",
    "register-commands": "ts-node -r tsconfig-paths/register register-guild-commands.ts",
    "seed:templates": "ts-node -r dotenv/config -r tsconfig-paths/register seed-templates.ts",
    "seed:platform-templates": "ts-node -r dotenv/config -r tsconfig-paths/register seed-platform-templates.ts",
    "update:templates": "ts-node -r dotenv/config -r tsconfig-paths/register update-templates.ts",
    "clear:test": "ts-node -r dotenv/config -r tsconfig-paths/register scripts/clear-test-state.ts",
    "qa:prep": "ts-node -r dotenv/config -r tsconfig-paths/register scripts/qa-prep.ts",
    "qa:admin-ops:local": "ts-node -r dotenv/config -r tsconfig-paths/register scripts/qa-admin-ops-local.ts",
    "qa:admin-ops:bloco-e:local": "ts-node -r dotenv/config -r tsconfig-paths/register scripts/qa-admin-ops-bloco-e-local.ts",
    "qa:webchat-wa": "jest --testPathPattern=\"ticket-public|webchat-whatsapp|whatsapp-agent|webchat-safe-url|inbox-agent-presence|webchat-faq\" && npm run qa:prep",
    "qa:webchat-wa:setup": "ts-node -r dotenv/config -r tsconfig-paths/register scripts/qa-webchat-wa-setup.ts",
    "qa:leads:setup": "ts-node -r dotenv/config -r tsconfig-paths/register scripts/qa-leads-form-setup.ts",
    "qa:atendimento:gate": "jest --testPathPattern=\"inbound-routing|csat\\.util|ticket-reply-window|ticket-public-access|whatsapp-agent|webchat-whatsapp|inbox-csat-gate|inbox-csat-reply|inbox-ticket-inbound|inbox-ticket-audit|inbox-inbound-order|consent-defer|webchat-faq|webchat-safe-url|inbox-agent-presence|panel-critical-alerts|whatsapp-session-rate-limit|whatsapp-human-send|webhook-events|webchat-bridge-webhook|attendance-audit|premium-ai\\.util|basic-triage\\.util|ai-credit-alerts|ai-credit-packages|ai-wallet|ai-credits|billing-state|plan-limit|mask-secret|wa-automated-peer|inbox-automated-peer\" && npm run qa:webchat-wa",
    "qa:atendimento:jest": "jest --testPathPattern=\"inbound-routing|csat\\.util|ticket-reply-window|ticket-public-access|whatsapp-agent|webchat-whatsapp|inbox-csat-gate|inbox-csat-reply|inbox-ticket-inbound|inbox-ticket-audit|inbox-inbound-order|consent-defer|webchat-faq|webchat-safe-url|inbox-agent-presence|panel-critical-alerts|whatsapp-session-rate-limit|whatsapp-human-send|webhook-events|webchat-bridge-webhook|attendance-audit|premium-ai\\.util|basic-triage\\.util|ai-credit-alerts|ai-credit-packages|ai-wallet|ai-credits|billing-state|plan-limit|mask-secret|wa-automated-peer|inbox-automated-peer\" --forceExit && jest --testPathPattern=\"ticket-public|webchat-whatsapp|whatsapp-agent|webchat-safe-url|inbox-agent-presence|webchat-faq\" --forceExit",
    "qa:gate": "npm test && npm run build && npm run build --prefix src/services/web-dashboard/frontend",
    "qa:manual:start": "npm run qa:atendimento:gate",
    "qa:fase1:e2e": "npm run build --prefix src/services/web-dashboard/frontend && playwright test e2e/inbox-authenticated.spec.ts e2e/atendimento-smoke.spec.ts e2e/attendance-modes.spec.ts e2e/qa-fase1-panel.spec.ts e2e/qa-fase1-presence.spec.ts e2e/leads-panel.spec.ts --project=chromium",
    "qa:fase1:all": "npm run qa:fase1:e2e && npm run qa:manual:start",
    "qa:campaign-limits": "jest --testPathPattern=\"campaign-(send-policy|inter-destination)\"",
    "qa:campaign-limits:e2e": "npm run build --prefix src/services/web-dashboard/frontend && playwright test e2e/qa-campaign-limits.spec.ts --project=chromium",
    "qa:campaign-limits:gate": "npm run qa:campaign-limits && npm run qa:campaign-limits:e2e",
    "qa:release-gate": "node scripts/qa-release-gate.mjs",
    "qa:auditoria:gate": "node scripts/qa-auditoria-geral.mjs",
    "qa:auditoria:quick": "node scripts/qa-auditoria-geral.mjs --quick",
    "pre-push:gate": "node scripts/pre-push-deploy-gate.mjs",
    "vps:hotfix:env": "node scripts/trigger-vps-hotfix-env.mjs",
    "vps:coolify:reconcile": "gh workflow run \"Coolify reconcile\"",
    "vps:coolify:verify": "gh workflow run \"Coolify verify\"",
    "backfill:webchat-delivered": "ts-node -r dotenv/config -r tsconfig-paths/register scripts/backfill-webchat-inbound-delivered-at.ts",
    "sync:widget-build": "node scripts/sync-widget-build.cjs",
    "deploy:radarchat": "node scripts/deploy-radarchat-ftp.mjs",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:handles": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e:install": "playwright install chromium",
    "pretest:e2e": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src/services/inbox/ticket-token-resend-otp.ts src/services/webchat/webchat-message-receipt.service.ts src/services/webchat/webchat-message-receipt-rate-limit.ts",
    "lint:all": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:infra": "docker compose up -d redis mongodb",
    "docker:down": "docker compose down",
    "migrate:v1-db": "powershell -ExecutionPolicy Bypass -File scripts/migrate-v1-db-to-v2.ps1",
    "docker:logs": "docker-compose logs -f",
    "setup": "npm run build && npm run docker:build",
    "deploy": "npm run test && npm run build && npm run docker:up"
  },
  "keywords": [
    "discord",
    "whatsapp",
    "automation",
    "bot",
    "microservices"
  ],
  "author": "Benhur Augusto Gomes Monteiro Faria",
  "license": "UNLICENSED",
  "dependencies": {
    "@bull-board/api": "^7.1.5",
    "@bull-board/express": "^7.1.5",
    "@discordjs/builders": "^1.8.2",
    "@discordjs/rest": "^2.3.0",
    "@hapi/boom": "^10.0.1",
    "@types/express-session": "^1.19.0",
    "@types/twilio": "^3.19.2",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "bullmq": "^5.12.0",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "discord-api-types": "^0.37.83",
    "discord.js": "^14.15.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.19.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.8.0",
    "mongoose": "^8.5.2",
    "nodemailer": "^9.0.1",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "pino-pretty": "^11.2.2",
    "qrcode": "^1.5.3",
    "socket.io": "^4.7.5",
    "twilio": "^5.8.0",
    "uuid": "^11.1.1",
    "winston": "^3.13.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^24.13.2",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.0.0",
    "redis-memory-server": "^0.10.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.3",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  },
  "overrides": {
    "undici": "6.27.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  }
}
