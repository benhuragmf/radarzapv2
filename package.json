{
  "name": "radarzap",
  "version": "2.7.2",
  "private": true,
  "description": "RadarZap — automação Discord para WhatsApp",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "dev": "node -r ./scripts/register-dev-logging.cjs ./node_modules/ts-node-dev/lib/bin.js --respawn --transpile-only -r tsconfig-paths/register src/index.ts",
    "dev:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-dev.ps1",
    "stripe:webhook": "powershell -ExecutionPolicy Bypass -File scripts/stripe-webhook-dev.ps1",
    "stripe:prices": "ts-node -r dotenv/config -r tsconfig-paths/register scripts/create-stripe-radarzap-prices.ts",
    "docker:prod": "docker compose -f docker-compose.prod.yml up -d --build",
    "dashboard": "ts-node -r tsconfig-paths/register start-dashboard.ts",
    "dashboard:frontend": "npm run dev --prefix src/services/web-dashboard/frontend",
    "register-commands": "ts-node -r tsconfig-paths/register register-guild-commands.ts",
    "seed:templates": "ts-node -r dotenv/config -r tsconfig-paths/register seed-templates.ts",
    "seed:platform-templates": "ts-node -r dotenv/config -r tsconfig-paths/register seed-platform-templates.ts",
    "update:templates": "ts-node -r dotenv/config -r tsconfig-paths/register update-templates.ts",
    "clear:test": "ts-node -r dotenv/config -r tsconfig-paths/register scripts/clear-test-state.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e:install": "playwright install chromium",
    "pretest:e2e": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:infra": "docker compose up -d redis mongodb",
    "docker:down": "docker compose down",
    "migrate:v1-db": "powershell -ExecutionPolicy Bypass -File scripts/migrate-v1-db-to-v2.ps1",
    "docker:logs": "docker-compose logs -f",
    "setup": "npm run build && npm run docker:build",
    "deploy": "npm run test && npm run build && npm run docker:up"
  },
  "keywords": [
    "discord",
    "whatsapp",
    "automation",
    "bot",
    "microservices"
  ],
  "author": "Benhur Augusto Gomes Monteiro Faria",
  "license": "UNLICENSED",
  "dependencies": {
    "@bull-board/api": "^7.1.5",
    "@bull-board/express": "^7.1.5",
    "@discordjs/builders": "^1.8.2",
    "@discordjs/rest": "^2.3.0",
    "@hapi/boom": "^10.0.1",
    "@types/express-session": "^1.19.0",
    "@types/twilio": "^3.19.2",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "bullmq": "^5.12.0",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "discord-api-types": "^0.37.83",
    "discord.js": "^14.15.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.19.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.8.0",
    "mongoose": "^8.5.2",
    "nodemailer": "^8.0.10",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "pino-pretty": "^11.2.2",
    "qrcode": "^1.5.3",
    "socket.io": "^4.7.5",
    "twilio": "^5.8.0",
    "uuid": "^11.1.1",
    "winston": "^3.13.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.12",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.0.0",
    "redis-memory-server": "^0.10.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.3",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
